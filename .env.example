# Smart Police Complaint & Accountability Portal — Environment Variables
# Copy this file to .env and fill in your values.

# ── API base URL ──
VITE_API_BASE_URL=http://localhost:3000

# ── Application ──
VITE_APP_NAME="Smart Police Complaint & Accountability Portal"
VITE_APP_SHORT_NAME=SPCAP

# ── Feature flags (optional) ──
VITE_ENABLE_MSW=false
VITE_PAYLOAD_ENCRYPTION_ENABLED=true
VITE_PAYLOAD_ENCRYPTION_KEY=your-encryption-key-here
VITE_PAYLOAD_ENCRYPTION_ALGORITHM=AES-256-CBC
VITE_PAYLOAD_ENCRYPTION_IV_LENGTH=16
VITE_PAYLOAD_ENCRYPTION_TAG_LENGTH=12
VITE_ENCRYPTED_PAYLOAD_SEPARATOR=-