# Smart Police Complaint & Accountability Portal — Environment Variables
# Copy this file to .env and fill in your values.

# ── API base URL ──
VITE_API_BASE_URL=http://localhost:3000

# ── Application ──
VITE_APP_NAME="Smart Police Complaint & Accountability Portal"
VITE_APP_SHORT_NAME=SPCAP

# ── Feature flags (optional) ──
VITE_ENABLE_MSW=false
